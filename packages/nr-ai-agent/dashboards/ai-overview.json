{
  "name": "AI Overview",
  "description": "Pre-built dashboard for nr-ai-agent observability. Requires AiRequest and AiResponse custom events sent by the nr-ai-agent package. Widgets will show 'No data' until the agent is actively sending telemetry.",
  "permissions": "PUBLIC_READ_WRITE",
  "pages": [
    {
      "name": "AI Overview",
      "description": "Key indicators, cost, performance, tokens, and errors for AI model usage",
      "widgets": [
        {
          "title": "Total AI Spend Today",
          "layout": { "column": 1, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT sum(`cost.totalUsd`) AS 'Total Cost (USD)' FROM AiResponse SINCE today"
              }
            ],
            "thresholds": [
              { "alertSeverity": "WARNING", "value": 10 },
              { "alertSeverity": "CRITICAL", "value": 100 }
            ]
          }
        },
        {
          "title": "Total Requests",
          "layout": { "column": 4, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT count(*) AS 'Requests' FROM AiRequest SINCE today"
              }
            ]
          }
        },
        {
          "title": "P95 Latency",
          "layout": { "column": 7, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT percentile(durationMs, 95) AS 'P95 (ms)' FROM AiResponse SINCE 1 hour ago"
              }
            ],
            "thresholds": [
              { "alertSeverity": "WARNING", "value": 5000 },
              { "alertSeverity": "CRITICAL", "value": 30000 }
            ]
          }
        },
        {
          "title": "Error Rate",
          "layout": { "column": 10, "row": 1, "width": 3, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT percentage(count(*), WHERE `error.type` IS NOT NULL) AS 'Error %' FROM AiResponse SINCE 1 hour ago"
              }
            ],
            "thresholds": [
              { "alertSeverity": "WARNING", "value": 5 },
              { "alertSeverity": "CRITICAL", "value": 20 }
            ]
          }
        },

        {
          "title": "Cost by Model",
          "layout": { "column": 1, "row": 4, "width": 6, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT sum(`cost.totalUsd`) FROM AiResponse FACET model TIMESERIES SINCE 24 hours ago"
              }
            ],
            "yAxisLeft": { "zero": true }
          }
        },
        {
          "title": "Cost by Provider",
          "layout": { "column": 7, "row": 4, "width": 6, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT sum(`cost.totalUsd`) FROM AiResponse FACET provider TIMESERIES SINCE 24 hours ago"
              }
            ],
            "yAxisLeft": { "zero": true }
          }
        },

        {
          "title": "Latency Percentiles",
          "layout": { "column": 1, "row": 7, "width": 4, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT percentile(durationMs, 50, 90, 95, 99) FROM AiResponse TIMESERIES SINCE 24 hours ago"
              }
            ]
          }
        },
        {
          "title": "Time to First Token by Model",
          "layout": { "column": 5, "row": 7, "width": 4, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT average(timeToFirstTokenMs) FROM AiResponse WHERE timeToFirstTokenMs IS NOT NULL FACET model TIMESERIES SINCE 24 hours ago"
              }
            ]
          }
        },
        {
          "title": "Tokens per Second by Model",
          "layout": { "column": 9, "row": 7, "width": 4, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT average(tokensPerSecond) FROM AiResponse FACET model TIMESERIES SINCE 24 hours ago"
              }
            ]
          }
        },

        {
          "title": "Token Distribution Over Time",
          "layout": { "column": 1, "row": 10, "width": 8, "height": 3 },
          "visualization": { "id": "viz.stacked-bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT sum(inputTokens) AS 'Input', sum(outputTokens) AS 'Output', sum(thinkingTokens) AS 'Thinking', sum(cacheReadTokens) AS 'Cache Read' FROM AiResponse TIMESERIES SINCE 24 hours ago"
              }
            ]
          }
        },
        {
          "title": "Stop Reason Distribution",
          "layout": { "column": 9, "row": 10, "width": 4, "height": 3 },
          "visualization": { "id": "viz.pie" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT count(*) FROM AiResponse FACET stopReason SINCE 24 hours ago"
              }
            ]
          }
        },

        {
          "title": "Error Rate Over Time",
          "layout": { "column": 1, "row": 13, "width": 6, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT percentage(count(*), WHERE `error.type` IS NOT NULL) AS 'Error %' FROM AiResponse TIMESERIES SINCE 24 hours ago"
              }
            ]
          }
        },
        {
          "title": "Recent Errors",
          "layout": { "column": 7, "row": 13, "width": 6, "height": 3 },
          "visualization": { "id": "viz.table" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT timestamp, model, `error.type`, `error.message`, `error.statusCode` FROM AiResponse WHERE `error.type` IS NOT NULL SINCE 1 hour ago LIMIT 20"
              }
            ]
          }
        }
      ]
    }
  ]
}
