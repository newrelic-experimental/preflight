{
  "name": "AI Coding Assistant — Personal",
  "description": "Self-reflection dashboard for a single developer. Pre-filtered to your identity. Deploy with: preflight deploy-dashboards ai-coding-assistant-personal.json --developer <your-name>",
  "permissions": "PRIVATE",
  "pages": [
    {
      "name": "My Trends",
      "description": "30-day rolling trends scoped to your activity",
      "widgets": [
        {
          "title": "Daily AI Spend",
          "layout": {
            "column": 1,
            "row": 3,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM AiCodingTask SELECT sum(estimated_cost_usd) AS 'Total Spend (USD)' WHERE developer = {{developer}} SINCE 30 DAYS AGO TIMESERIES 1 DAY"
              }
            ]
          }
        },
        {
          "title": "Efficiency Score Trend",
          "layout": {
            "column": 1,
            "row": 6,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT average(ai.efficiency.score) AS 'Avg Efficiency Score' WHERE developer = {{developer}} SINCE 30 DAYS AGO TIMESERIES 1 DAY"
              }
            ]
          }
        },
        {
          "title": "Tool Calls Per Day",
          "layout": {
            "column": 7,
            "row": 6,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT count(*) FROM AiToolCall WHERE developer = {{developer}} SINCE 30 days ago TIMESERIES 1 day"
              }
            ]
          }
        },
        {
          "title": "Anti-Pattern Type Breakdown",
          "layout": {
            "column": 7,
            "row": 3,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.pie"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT count(*) FROM AiAntiPattern WHERE developer = {{developer}} SINCE 30 days ago FACET type"
              }
            ]
          }
        },
        {
          "title": "Sessions Per Day",
          "layout": {
            "column": 1,
            "row": 9,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT uniqueCount(session_id) FROM AiToolCall WHERE developer = {{developer}} SINCE 30 days ago TIMESERIES 1 day"
              }
            ]
          }
        },
        {
          "title": "30-Day Total Spend",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 2
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM AiCodingTask SELECT sum(estimated_cost_usd) AS 'Total Spend (USD)' WHERE developer = {{developer}} SINCE 30 DAYS AGO"
              }
            ]
          }
        },
        {
          "title": "Avg Efficiency This Week",
          "layout": {
            "column": 5,
            "row": 1,
            "width": 4,
            "height": 2
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT average(ai.efficiency.score) AS 'Avg Efficiency Score' WHERE developer = {{developer}} SINCE THIS WEEK"
              }
            ]
          }
        },
        {
          "title": "Total Sessions This Month",
          "layout": {
            "column": 9,
            "row": 1,
            "width": 4,
            "height": 2
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT uniqueCount(session_id) AS 'Sessions' FROM AiToolCall WHERE developer = {{developer}} SINCE 30 days ago"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "My Patterns",
      "description": "Repeating behaviours and potential inefficiencies",
      "widgets": [
        {
          "title": "My Top Anti-Patterns",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.bar"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT count(*) FROM AiAntiPattern WHERE developer = {{developer}} SINCE 30 days ago FACET type"
              }
            ]
          }
        },
        {
          "title": "Anti-Pattern Rate Over Time",
          "layout": {
            "column": 7,
            "row": 1,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT count(*) FROM AiAntiPattern WHERE developer = {{developer}} SINCE 30 days ago TIMESERIES 1 day"
              }
            ]
          }
        },
        {
          "title": "Most-Read Files (Top 10)",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT count(*) AS 'Reads' FROM AiToolCall WHERE developer = {{developer}} AND tool = 'Read' AND filePath IS NOT NULL SINCE 30 days ago FACET filePath LIMIT 10"
              }
            ]
          }
        },
        {
          "title": "Read Fraction",
          "layout": {
            "column": 7,
            "row": 4,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT filter(count(*), WHERE tool = 'Read') / filter(count(*), WHERE tool IN ('Read','Edit','Write')) AS 'Read Fraction' FROM AiToolCall WHERE developer = {{developer}} SINCE 7 days ago"
              }
            ]
          }
        },
        {
          "title": "Tool Usage Breakdown",
          "layout": {
            "column": 1,
            "row": 7,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.pie"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT count(*) FROM AiToolCall WHERE developer = {{developer}} SINCE 30 days ago FACET tool"
              }
            ]
          }
        },
        {
          "title": "Avg Tools Per Session",
          "layout": {
            "column": 5,
            "row": 7,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT count(*) / uniqueCount(session_id) AS 'Avg Tools / Session' FROM AiToolCall WHERE developer = {{developer}} SINCE 30 days ago"
              }
            ]
          }
        },
        {
          "title": "Edit vs. Read Ratio",
          "layout": {
            "column": 9,
            "row": 7,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT filter(count(*), WHERE tool IN ('Edit','Write')) / filter(count(*), WHERE tool = 'Read') AS 'Edit:Read Ratio' FROM AiToolCall WHERE developer = {{developer}} SINCE 30 days ago TIMESERIES 1 day"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "My Best Sessions",
      "description": "Top-performing sessions to understand what worked well",
      "widgets": [
        {
          "title": "Top 5 Sessions by Activity",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT uniqueCount(task_id) AS 'Tasks', sum(estimated_cost_usd) AS 'Cost (USD)', sum(tool_call_count) AS 'Tool Calls' FROM AiCodingTask WHERE developer = {{developer}} SINCE 90 days ago FACET session_id LIMIT 5"
              }
            ]
          }
        },
        {
          "title": "All-Time Best Efficiency Score",
          "layout": {
            "column": 7,
            "row": 1,
            "width": 3,
            "height": 3
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "FROM Metric SELECT max(ai.efficiency.score) AS 'Personal Best' WHERE developer = {{developer}} SINCE 90 DAYS AGO"
              }
            ]
          }
        },
        {
          "title": "Sessions With Zero Anti-Patterns",
          "layout": {
            "column": 10,
            "row": 1,
            "width": 3,
            "height": 3
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT uniqueCount(session_id) AS 'Clean Sessions' FROM AiToolCall WHERE developer = {{developer}} AND session_id NOT IN (SELECT uniques(session_id) FROM AiAntiPattern WHERE developer = {{developer}} SINCE 30 days ago) SINCE 30 days ago"
              }
            ]
          }
        },
        {
          "title": "Avg Cost Per Completed Task",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT average(estimated_cost_usd) AS 'Cost / Task (USD)' FROM AiCodingTask WHERE developer = {{developer}} SINCE 30 days ago TIMESERIES 1 week"
              }
            ]
          }
        },
        {
          "title": "Most Productive Day of Week",
          "layout": {
            "column": 7,
            "row": 4,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.bar"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [],
                "query": "SELECT count(*) AS 'Tool Calls' FROM AiToolCall WHERE developer = {{developer}} SINCE 90 days ago FACET weekdayOf(timestamp)"
              }
            ]
          }
        }
      ]
    }
  ],
  "variables": [
    {
      "name": "developer",
      "title": "Developer",
      "type": "NRQL",
      "nrqlQuery": {
        "query": "SELECT uniques(developer) FROM AiToolCall SINCE 90 days ago",
        "accountIds": [0]
      },
      "isMultiSelection": false,
      "defaultValues": [],
      "replacementStrategy": "STRING",
      "options": {
        "excluded": false
      }
    }
  ]
}
